# ── Proveedor de IA (elige uno o varios; el sistema usa el primero disponible) ──
AI_PROVIDER=claude            # claude | openai | gemini | deepseek
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# Modelos (opcional, hay defaults sensatos)
CLAUDE_MODEL=claude-sonnet-4-5
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-2.0-flash
DEEPSEEK_MODEL=deepseek-chat

# ── Búsqueda SERP (elige uno; ddg no requiere key pero es menos fiable) ──
SEARCH_PROVIDER=serpapi       # serpapi | brave | ddg
SERPAPI_KEY=
BRAVE_API_KEY=

# ── Imágenes de stock (gratuitas, sin derechos de autor problemáticos) ──
PEXELS_API_KEY=
PIXABAY_API_KEY=
UNSPLASH_ACCESS_KEY=

# ── Generación de imágenes por IA (último recurso) ──
IMAGE_AI_PROVIDER=openai      # openai (dall-e-3) | none

# ── Salida ──
# Publica directo en la carpeta public/ del sitio React (se sirve como /blog/...)
OUTPUT_DIR=../public/blog
SITE_BASE_URL=https://easyprodigital.com/blog
# Raíz del sitio principal para los enlaces "volver al sitio" de las plantillas.
# Déjalo vacío para usar enlaces relativos ('/'), recomendado si el blog vive en el mismo dominio.
SITE_URL=
LANGUAGE=es
MIN_IMAGE_WIDTH=1200
MIN_IMAGE_HEIGHT=675
